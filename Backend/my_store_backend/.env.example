# 🔧 Environment Variables Template
# Copy this file to .env and fill in your actual values

# ========================
# Database Configuration
# ========================
# For FreeSQLDatabase.com:
DB_HOST=sql12.freesqldatabase.com
DB_USER=sql12xxxxx
DB_PASSWORD=your-password-here
DB_NAME=sql12xxxxx
DB_PORT=3306

# For db4free.net:
# DB_HOST=db4free.net
# DB_USER=your-username
# DB_PASSWORD=your-password
# DB_NAME=your-database
# DB_PORT=3306

# ========================
# JWT Secret
# ========================
# Generate random string (min 32 chars): 
# PowerShell: -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 32 | ForEach-Object {[char]$_})
JWT_SECRET=change-this-to-random-32-characters-or-longer

# ========================
# Google Gemini AI
# ========================
# Get API key from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# ========================
# Server Configuration
# ========================
PORT=3006
NODE_ENV=development

# ========================
# Ngrok (Optional - for local testing)
# ========================
USE_NGROK=false
NGROK_URL=

# ========================
# Email Configuration (Optional)
# ========================
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# FRONTEND_URL=http://localhost:3000

# ========================
# VNPay Configuration (Optional)
# ========================
# VNPAY_TMN_CODE=your-tmn-code
# VNPAY_HASH_SECRET=your-hash-secret
# VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
